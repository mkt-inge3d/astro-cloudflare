          <img src="/partners/autodesk-gold.png" alt="Autodesk Gold Partner" />
          <img src="/partners/ansys-esss.png" alt="Ansys ESSS Partner" />
          <img src="/partners/oracle-partner.png" alt="Oracle Partner" class="footer-partner--dark" />
        </div>
