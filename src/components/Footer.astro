      <!-- Col 4: Sedes + Compliance -->
      <div class="footer-col">
        <h4>Nuestras sedes</h4>
        <div class="footer-contact-block">
          <p><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg> Av. Brígida Silva de Ochoa N° 398, Of. 507, San Miguel, Lima</p>
          <p><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg> Calle Los Antares N° 320, Of. 903 – Torre A, Santiago de Surco, Lima</p>
        </div>
        <div class="footer-compliance">
          <a href="https://www.semco.com.pe/libro-de-reclamaciones-semco/" target="_blank" rel="noopener" class="compliance-link">
            <img src="/libro-reclamaciones.png" alt="Libro de Reclamaciones" />
          </a>
          <a href="https://www.semco.com.pe/denuncias-antisoborno/" target="_blank" rel="noopener" class="compliance-link">
            <img src="/denuncias-antisoborno.png" alt="Denuncias Antisoborno" />
