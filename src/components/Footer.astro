</footer>

<style is:inline>
  /* ===== Social Bar ===== */
  .footer-social-bar {
    background: var(--navy);
    padding: 0.75rem 2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .footer-social-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: flex-end;
    gap: 1rem;
  }

  .footer-social-bar a {
    color: rgba(255, 255, 255, 0.5);
    transition: color 0.3s ease, transform 0.3s ease;
    display: flex;
    align-items: center;
  }

  .footer-social-bar a:hover {
    color: var(--orange);
    transform: translateY(-2px);
  }

  /* ===== Main Footer ===== */
  .footer-main {
    background: var(--navy);
    padding: 3.5rem 2rem 2.5rem;
  }

  .footer-main-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr;
    gap: 2.5rem;
  }

  .footer-col h4 {
    color: var(--orange);
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 0.8rem;
    padding-bottom: 0.5rem;
    position: relative;
  }

  .footer-col h4::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 24px;
    height: 2px;
    background: var(--orange);
    border-radius: 2px;
    opacity: 0.5;
  }

  .footer-col h4:not(:first-child) {
    margin-top: 1.5rem;
  }

  /* ===== Brand Column ===== */
  .footer-logo {
    height: 40px;
    width: auto;
    margin-bottom: 1rem;
  }

  .footer-about {
    font-size: 0.85rem;
    color: rgba(176, 190, 197, 0.7);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .footer-partners {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    flex-wrap: wrap;
  }

  .footer-partners img {
    height: 32px;
    width: auto;
    object-fit: contain;
    opacity: 0.7;
    transition: opacity 0.3s ease;
  }

  .footer-partners img:hover {
    opacity: 1;
  }

  .footer-partner--dark {
    background: rgba(255, 255, 255, 0.05);
    padding: 4px 8px;
    border-radius: 4px;
  }

  /* ===== Contact Blocks ===== */
  .footer-contact-block {
    margin-bottom: 0.5rem;
  }

  .footer-contact-block p {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.82rem;
    color: rgba(176, 190, 197, 0.75);
    line-height: 1.6;
    margin-bottom: 0.35rem;
  }

  .footer-contact-block p svg {
    flex-shrink: 0;
    margin-top: 3px;
    color: rgba(255, 107, 53, 0.6);
  }

  /* ===== Compliance ===== */
  .footer-compliance {
    display: flex;
    gap: 1rem;
    margin-top: 1.5rem;
    flex-wrap: wrap;
  }

  .compliance-link {
    display: block;
    transition: transform 0.3s ease, opacity 0.3s ease;
    opacity: 0.8;
  }

  .compliance-link:hover {
    transform: translateY(-2px);
    opacity: 1;
  }

  .compliance-link img {
    height: 72px;
    width: auto;
    object-fit: contain;
  }

  /* ===== Bottom Bar ===== */
  .footer-bottom {
    background: #0d1520;
    padding: 1rem 2rem;
  }

  .footer-bottom-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .footer-bottom p {
    font-size: 0.8rem;
    color: rgba(176, 190, 197, 0.5);
  }

  .footer-legal {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .footer-legal a {
    font-size: 0.8rem;
    color: rgba(176, 190, 197, 0.5);
    transition: color 0.3s ease;
  }

  .footer-legal a:hover {
    color: var(--orange);
  }

  .footer-legal-sep {
    color: rgba(176, 190, 197, 0.2);
    font-size: 0.8rem;
  }

  /* ===== Responsive ===== */
  @media (max-width: 1024px) {
    .footer-main-inner {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
  }

  @media (max-width: 640px) {
    .footer-main-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .footer-social-inner {
      justify-content: center;
    }

    .footer-bottom-inner {
      flex-direction: column;
      text-align: center;
    }

    .footer-compliance {
      justify-content: center;
    }

    .footer-partners {
      justify-content: center;
    }
  }
</style>
