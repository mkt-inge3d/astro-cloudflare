---
interface Props {
  title: string;
  badge: string;
  headline: string;
  description: string;
  breadcrumb: string;
  contactEmail?: string;
  contactPhone?: string;
}

import Layout from './Layout.astro';

const {
  title,
  badge,
  headline,
  description,
  breadcrumb,
  contactEmail = 'informes@semco.com.pe',
  contactPhone = '(01) 202 7908',
} = Astro.props;
---

<Layout title={`${title} | SemcoCAD`} description={description}>
  <section class="sp-hero">
    <div class="sp-hero-bg"></div>
    <div class="sp-hero-inner">
      <nav class="breadcrumb fade-up">
        <a href="/">Home</a>
        <svg width="6" height="10" viewBox="0 0 6 10" fill="none"><path d="M1 1l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        <Fragment set:html={breadcrumb} />
      </nav>
      <div class="sp-hero-content fade-up">
        <span class="sp-badge">{badge}</span>
        <h1>{headline}</h1>
        <p>{description}</p>
        <div class="sp-hero-actions">
          <a href="/contacto" class="btn-primary">Solicitar información</a>
        </div>
      </div>
    </div>
  </section>

  <slot />

  <section class="sp-cta">
    <div class="sp-cta-inner fade-up">
      <h2>¿Necesita más información?</h2>
      <p>Contáctenos y nuestro equipo lo asesorará en la mejor solución para su empresa.</p>
      <div class="sp-cta-actions">
        <a href="/contacto" class="btn-primary">Contáctanos</a>
        <a href={`tel:${contactPhone.replace(/[^+\d]/g, '')}`} class="btn-outline">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          {contactPhone}
        </a>
      </div>
      <p class="sp-cta-email"><a href={`mailto:${contactEmail}`}>{contactEmail}</a></p>
    </div>
  </section>
</Layout>

<style is:global>
  .sp-hero { position: relative; min-height: 360px; display: flex; align-items: flex-end; overflow: hidden; }
  .sp-hero-bg { position: absolute; inset: 0; background: linear-gradient(135deg, #0f1923 0%, #1a2332 50%, #1e3a5f 100%); z-index: 0; }
  .sp-hero-bg::before { content: ''; position: absolute; top: -30%; right: -10%; width: 500px; height: 500px; background: radial-gradient(circle, rgba(255,107,53,0.08) 0%, transparent 70%); border-radius: 50%; }
  .sp-hero-bg::after { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg, transparent, rgba(255,107,53,0.3), transparent); }
  .sp-hero-inner { position: relative; z-index: 1; max-width: 1200px; margin: 0 auto; padding: 7rem 2rem 3.5rem; width: 100%; }
  .breadcrumb { display: flex; align-items: center; gap: 0.5rem; font-size: 0.85rem; color: rgba(176,190,197,0.7); margin-bottom: 1.5rem; flex-wrap: wrap; }
  .breadcrumb a { color: rgba(176,190,197,0.7); transition: color 0.3s; }
  .breadcrumb a:hover { color: var(--orange); }
  .breadcrumb svg { opacity: 0.4; }
  .breadcrumb span { color: var(--white); }
  .sp-badge { display: inline-block; background: rgba(255,107,53,0.12); color: var(--orange); font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; padding: 0.4rem 1rem; border-radius: 100px; border: 1px solid rgba(255,107,53,0.2); margin-bottom: 1rem; }
  .sp-hero-content h1 { font-size: 2.8rem; font-weight: 800; color: var(--white); margin-bottom: 1rem; line-height: 1.15; }
  .sp-hero-content > p { font-size: 1.1rem; color: rgba(176,190,197,0.85); max-width: 600px; line-height: 1.7; margin-bottom: 2rem; }
  .sp-hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
  .btn-primary { display: inline-flex; align-items: center; gap: 0.5rem; background: var(--orange); color: var(--white); padding: 0.9rem 2rem; border-radius: 8px; font-weight: 600; font-size: 0.95rem; transition: all 0.3s; border: 2px solid var(--orange); }
  .btn-primary:hover { background: var(--orange-hover); border-color: var(--orange-hover); transform: translateY(-2px); box-shadow: 0 8px 25px rgba(255,107,53,0.3); }
  .btn-outline { display: inline-flex; align-items: center; gap: 0.5rem; background: transparent; color: var(--orange); padding: 0.9rem 2rem; border-radius: 8px; font-weight: 600; font-size: 0.95rem; border: 2px solid var(--orange); transition: all 0.3s; }
  .btn-outline:hover { background: rgba(255,107,53,0.08); transform: translateY(-2px); }

  /* Sections */
  .sp-section { padding: 5rem 2rem; max-width: 1100px; margin: 0 auto; }
  .sp-section--gray { padding: 5rem 2rem; background: var(--gray-50); }
  .sp-section--gray > .sp-section-inner { max-width: 1100px; margin: 0 auto; }
  .sp-section-header { text-align: center; max-width: 620px; margin: 0 auto 3rem; }
  .sp-tag { display: inline-block; background: linear-gradient(135deg, rgba(255,107,53,0.1), rgba(255,107,53,0.05)); color: var(--orange); font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; padding: 0.35rem 1rem; border-radius: 100px; margin-bottom: 1rem; border: 1px solid rgba(255,107,53,0.15); }
  .sp-section-header h2 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.75rem; line-height: 1.2; }
  .sp-section-header p { font-size: 1rem; color: var(--gray-600); line-height: 1.6; }

  .sp-grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .sp-grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
  .sp-card { background: var(--white); border: 1px solid var(--gray-200); border-radius: 12px; padding: 2rem 1.5rem; transition: all 0.4s ease; }
  .sp-card:hover { transform: translateY(-4px); box-shadow: 0 12px 30px rgba(0,0,0,0.08); border-color: rgba(255,107,53,0.2); }
  .sp-card-icon { width: 44px; height: 44px; color: var(--orange); margin-bottom: 1rem; }
  .sp-card-icon svg { width: 100%; height: 100%; }
  .sp-card h3 { font-size: 1.05rem; font-weight: 700; margin-bottom: 0.5rem; }
  .sp-card p { font-size: 0.88rem; color: var(--gray-600); line-height: 1.6; }

  .sp-text-block { max-width: 800px; margin: 0 auto; }
  .sp-text-block h2 { font-size: 1.8rem; font-weight: 800; margin-bottom: 1rem; }
  .sp-text-block p { font-size: 1rem; color: var(--gray-600); line-height: 1.8; margin-bottom: 1rem; }
  .sp-text-block strong { color: var(--navy); }

  /* CTA */
  .sp-cta { background: linear-gradient(135deg, var(--orange) 0%, #e85a25 50%, #c44a1a 100%); padding: 4.5rem 2rem; text-align: center; position: relative; overflow: hidden; }
  .sp-cta::before { content: ''; position: absolute; top: -80px; right: -80px; width: 300px; height: 300px; background: rgba(255,255,255,0.05); border-radius: 50%; }
  .sp-cta-inner { position: relative; z-index: 1; max-width: 650px; margin: 0 auto; }
  .sp-cta h2 { color: var(--white); font-size: 2rem; font-weight: 800; margin-bottom: 1rem; }
  .sp-cta p { color: rgba(255,255,255,0.9); font-size: 1.05rem; line-height: 1.6; margin-bottom: 2rem; }
  .sp-cta-actions { display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap; margin-bottom: 1rem; }
  .sp-cta .btn-primary { background: var(--white); color: var(--orange); border-color: var(--white); }
  .sp-cta .btn-primary:hover { background: var(--gray-50); border-color: var(--gray-50); box-shadow: 0 8px 25px rgba(0,0,0,0.2); }
  .sp-cta .btn-outline { color: var(--white); border-color: rgba(255,255,255,0.5); }
  .sp-cta .btn-outline:hover { border-color: var(--white); background: rgba(255,255,255,0.1); }
  .sp-cta-email { font-size: 0.9rem !important; margin-bottom: 0 !important; }
  .sp-cta-email a { color: var(--white); text-decoration: underline; text-underline-offset: 2px; }

  .fade-up { opacity: 0; transform: translateY(30px); transition: opacity 0.7s cubic-bezier(0.25,0.46,0.45,0.94), transform 0.7s cubic-bezier(0.25,0.46,0.45,0.94); }
  .fade-up.visible { opacity: 1; transform: translateY(0); }

  @media (max-width: 900px) {
    .sp-hero-content h1 { font-size: 2.2rem; }
    .sp-grid-3 { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .sp-hero-content h1 { font-size: 1.8rem; }
    .sp-hero-inner { padding: 6rem 1.5rem 3rem; }
    .sp-grid-3, .sp-grid-2 { grid-template-columns: 1fr; }
    .sp-section-header h2 { font-size: 1.7rem; }
  }
</style>

<script is:inline>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const parent = entry.target.parentElement;
        if (parent) {
          const siblings = Array.from(parent.querySelectorAll('.fade-up'));
          const idx = siblings.indexOf(entry.target);
          setTimeout(() => entry.target.classList.add('visible'), idx >= 0 ? idx * 80 : 0);
        } else {
          entry.target.classList.add('visible');
        }
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
  document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));
</script>
