---
import Layout from '../layouts/Layout.astro';
---

<Layout title="SemcoCAD - Soluciones CAD, BIM y CAE para tu empresa">
  <!-- Hero Slider -->
  <section class="hero">
    <!-- Slide 1: Principal -->
    <div class="hero-slide hero-slide--active" data-slide="0">
      <img src="/logos/bg arqui (1) (1).webp" alt="" class="hero-bg-img" fetchpriority="high" decoding="async" />
      <div class="hero-overlay"></div>
      <div class="hero-inner">
        <div class="hero-text">
          <h1>Soluciones CAD, BIM y CAE<br/>para tu empresa</h1>
          <p class="hero-subtitle">
            Somos el proveedor líder en Perú de licencias de software, capacitación
            especializada y servicios de ingeniería para los sectores de diseño,
            construcción y manufactura.
          </p>
          <div class="hero-buttons">
            <a href="/licencias" class="cta-primary">Ver licencias</a>
            <a href="/cursos" class="cta-secondary">Cursos certificados</a>
          </div>
        </div>
        <div class="hero-visual hidden-mobile">
          <div class="globe">
            <div class="globe-ring">
              <img src="/isotipo-semco.png" alt="" class="globe-ring-icon" loading="lazy" decoding="async" />
            </div>
            <img src="/logo-blanco.webp" alt="SemcoCAD" class="globe-logo" loading="lazy" decoding="async" />
          </div>
          <a href="/licencias/autodesk/revit" class="orbit-card orbit-1">
            <img src="/logos/revit.webp" alt="Revit" class="orbit-logo" loading="lazy" decoding="async" />
          </a>
          <a href="/licencias/autodesk/autocad" class="orbit-card orbit-2">
            <img src="/logos/autocad.webp" alt="AutoCAD" class="orbit-logo" loading="lazy" decoding="async" />
          </a>
          <a href="/licencias/ansys/cfd" class="orbit-card orbit-3">
            <img src="/logos/ansys.webp" alt="Ansys" class="orbit-logo" loading="lazy" decoding="async" />
          </a>
          <a href="/licencias/autodesk/inventor" class="orbit-card orbit-4">
            <img src="/logos/inventor.webp" alt="Inventor" class="orbit-logo" loading="lazy" decoding="async" />
          </a>
          <a href="/licencias/oracle/primavera" class="orbit-card orbit-5">
            <img src="/logos/oracle.webp" alt="Oracle" class="orbit-logo" loading="lazy" decoding="async" />
          </a>
        </div>
      </div>
    </div>

    <!-- Slide 2: Evento Webinar -->
    <div class="hero-slide" data-slide="1">
      <img src="/logos/bg arqui (1) (1).webp" alt="" class="hero-bg-img" loading="lazy" decoding="async" />
      <div class="hero-overlay"></div>
      <div class="hero-inner hero-inner--event">
        <div class="hero-text">
          <span class="event-badge">Webinar gratuito <span class="event-live">EN VIVO</span></span>
          <p class="event-pre">Del Caos al Control</p>
          <h1>Cómo centralizar la información en proyectos de construcción</h1>
          <p class="hero-subtitle hero-subtitle--event">Aprende a gestionar documentación, modelos BIM y datos de obra en una sola plataforma.</p>
          <div class="event-details">
            <div class="event-detail">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              <span>Lunes 06 de Abril</span>
            </div>
            <div class="event-detail">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <span>08:00 PM (hora Perú)</span>
            </div>
            <div class="event-detail">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              <span>Incluye certificado</span>
            </div>
          </div>
          <div class="hero-buttons">
            <a href="/eventos/del-caos-al-control" class="cta-primary">Inscribirme gratis</a>
          </div>
        </div>
        <div class="hero-event-img hidden-mobile">
          <img src="/logos/equipo nube.webp" alt="Webinar: Del Caos al Control" loading="lazy" decoding="async" />
          <img src="/logos/equipo nube.webp" alt="" class="event-reflection" aria-hidden="true" loading="lazy" decoding="async" />
        </div>
      </div>
    </div>

    <!-- Slider controls -->
    <div class="slider-dots">
      <button class="slider-dot slider-dot--active" data-goto="0" aria-label="Slide 1"></button>
      <button class="slider-dot" data-goto="1" aria-label="Slide 2"></button>
    </div>
    <button class="slider-arrow slider-arrow--left" aria-label="Anterior">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
    </button>
    <button class="slider-arrow slider-arrow--right" aria-label="Siguiente">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
    </button>

    <div class="scroll-indicator">
      <div class="scroll-line"></div>
    </div>
  </section>

  <!-- Nuestros Servicios -->
  <section class="servicios" id="servicios">
    <div class="section-header fade-up">

      <h2>Soluciones integrales para tu empresa</h2>
      <p class="section-desc">Ofrecemos licenciamiento de software, capacitación certificada y servicios de ingeniería para potenciar tus proyectos.</p>
    </div>
    <div class="servicios-grid">
      <a href="/licencias/oracle/primavera" class="servicio-card fade-up">
        <div class="servicio-img">
          <img src="/logos/oracle1.webp" alt="Licencias Oracle" loading="lazy" decoding="async" />
          <div class="servicio-overlay"></div>
        </div>
        <div class="servicio-content">
          <h3>Licencias Oracle</h3>
          <p>Soluciones empresariales para gestión de proyectos: Primavera P6, Unifier y Aconex.</p>
          <span class="servicio-link">Conocer más <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
        </div>
      </a>
      <a href="/licencias/autodesk" class="servicio-card fade-up" data-link="autodesk">
        <div class="servicio-img">
          <img src="/logos/autodesk1 (1).webp" alt="Licencias Autodesk" loading="lazy" decoding="async" />
          <div class="servicio-overlay"></div>
        </div>
        <div class="servicio-content">
          <h3>Licencias Autodesk</h3>
          <p>AutoCAD, Revit, Civil 3D, Inventor y toda la suite de diseño CAD/BIM.</p>
          <span class="servicio-link">Conocer más <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
        </div>
      </a>
      <a href="/licencias/ansys" class="servicio-card fade-up">
        <div class="servicio-img">
          <img src="/logos/avion1.webp" alt="Licencias Ansys" loading="lazy" decoding="async" />
          <div class="servicio-overlay"></div>
        </div>
        <div class="servicio-content">
          <h3>Licencias Ansys</h3>
          <p>Software de simulación y análisis de ingeniería: CFD, mecánica estructural y más.</p>
          <span class="servicio-link">Conocer más <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
        </div>
      </a>
      <a href="/cronograma" class="servicio-card fade-up">
        <div class="servicio-img">
          <img src="/logos/clases1.webp" alt="Cronograma de Cursos" loading="lazy" decoding="async" />
          <div class="servicio-overlay"></div>
        </div>
        <div class="servicio-content">
          <h3>Cronograma de Cursos</h3>
          <p>Capacitación certificada en las herramientas más demandadas del mercado.</p>
          <span class="servicio-link">Ver cursos <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
        </div>
      </a>
      <a href="/eventos" class="servicio-card fade-up">
        <div class="servicio-img">
          <img src="/logos/eventos1.webp" alt="Eventos" loading="lazy" decoding="async" />
          <div class="servicio-overlay"></div>
        </div>
        <div class="servicio-content">
          <h3>Eventos</h3>
          <p>Webinars, seminarios y eventos de la industria CAD, BIM y CAE.</p>
          <span class="servicio-link">Ver eventos <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
        </div>
      </a>
      <a href="/cursos" class="servicio-card fade-up">
        <div class="servicio-img">
          <img src="/logos/plat_form (1).webp" alt="Campus Virtual" loading="lazy" decoding="async" />
          <div class="servicio-overlay"></div>
        </div>
        <div class="servicio-content">
          <h3>Campus Virtual</h3>
          <p>Plataforma de aprendizaje en línea con contenido especializado.</p>
          <span class="servicio-link">Acceder <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
        </div>
      </a>
    </div>
  </section>

  <!-- Especializaciones -->
  <section class="especializaciones" id="especializaciones">
    <div class="section-header fade-up">

      <h2>Programas de especialización profesional</h2>
      <p class="section-desc">Desarrolla competencias avanzadas en BIM, diseño paramétrico, simulación y gestión de proyectos.</p>
    </div>
    <div class="espec-grid">
      <div class="espec-card fade-up" style="--bg: url('/logos/obra1 (1).jpg')">
        <div class="espec-card-bg"></div>
        <div class="espec-card-content">
          <span class="espec-badge">BIM</span>
          <h3>Edificaciones</h3>
          <p>Especialización BIM para proyectos de arquitectura e ingeniería de edificaciones.</p>
          <a href="/especializacion/bim-edificaciones" class="espec-btn">Ver programa</a>
        </div>
      </div>
      <div class="espec-card fade-up" style="--bg: url('/logos/plantas1 (1).jpg')">
        <div class="espec-card-bg"></div>
        <div class="espec-card-content">
          <span class="espec-badge">BIM</span>
          <h3>Plantas Industriales</h3>
          <p>Modelado y gestión BIM para proyectos de plantas industriales y procesamiento.</p>
          <a href="/especializacion/bim-plantas-industriales" class="espec-btn">Ver programa</a>
        </div>
      </div>
      <div class="espec-card fade-up" style="--bg: url('/logos/prototipos_digitales.webp')">
        <div class="espec-card-bg"></div>
        <div class="espec-card-content">
          <span class="espec-badge">PIM</span>
          <h3>Prototipos Digitales</h3>
          <p>Innovación en diseño de productos con prototipos digitales y manufactura avanzada.</p>
          <a href="/especializacion/pim-prototipos-digitales" class="espec-btn">Ver programa</a>
        </div>
      </div>
      <div class="espec-card fade-up" style="--bg: url('/logos/InfraWorks_go.webp')">
        <div class="espec-card-bg"></div>
        <div class="espec-card-content">
          <span class="espec-badge">BIM</span>
          <h3>Infraestructura</h3>
          <p>BIM aplicado a infraestructura vial, civil y obras de gran envergadura.</p>
          <a href="/especializacion/bim-infraestructura" class="espec-btn">Ver programa</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Estadísticas -->
  <section class="stats-section">
    <div class="stats-header fade-up">

      <h2>¿Por qué elegirnos?</h2>
      <p class="section-desc">Te damos 6 razones para confiar en nosotros como tu socio estratégico en tecnología e ingeniería.</p>
    </div>
    <div class="stats-grid">
      <div class="stat-card fade-up">
        <span class="stat-bg-num">1</span>
        <div class="stat-icon">
          <img loading="lazy" decoding="async" src="/logos/confianza/Años de experiencia.webp" alt="" />
        </div>
        <span class="stat-num">38+</span>
        <span class="stat-label">Años de experiencia</span>
        <p class="stat-desc">Desde 1988 brindando soluciones tecnológicas de ingeniería en el Perú.</p>
      </div>
      <div class="stat-card fade-up">
        <span class="stat-bg-num">2</span>
        <div class="stat-icon">
          <img loading="lazy" decoding="async" src="/logos/confianza/Profesionales capacitados.webp" alt="" />
        </div>
        <span class="stat-num">5,000+</span>
        <span class="stat-label">Profesionales capacitados</span>
        <p class="stat-desc">Miles de profesionales formados con certificación internacional.</p>
      </div>
      <div class="stat-card fade-up">
        <span class="stat-bg-num">3</span>
        <div class="stat-icon">
          <img loading="lazy" decoding="async" src="/logos/confianza/Empresas confían en nosotros.webp" alt="" />
        </div>
        <span class="stat-num">200+</span>
        <span class="stat-label">Empresas confían en nosotros</span>
        <p class="stat-desc">Empresas líderes del sector nos eligen como socio estratégico.</p>
      </div>
      <div class="stat-card fade-up">
        <span class="stat-bg-num">4</span>
        <div class="stat-icon">
          <img loading="lazy" decoding="async" src="/logos/confianza/Cursos especializados.webp" alt="" />
        </div>
        <span class="stat-num">50+</span>
        <span class="stat-label">Cursos especializados</span>
        <p class="stat-desc">Catálogo completo en CAD, BIM, CAE y gestión de proyectos.</p>
      </div>
      <div class="stat-card fade-up">
        <span class="stat-bg-num">5</span>
        <div class="stat-icon">
          <img loading="lazy" decoding="async" src="/logos/confianza/Partner Autodesk.webp" alt="" />
        </div>
        <span class="stat-num stat-num--text">Gold</span>
        <span class="stat-label">Partner Autodesk</span>
        <p class="stat-desc">Reconocidos como partner Gold autorizado de Autodesk en Perú.</p>
      </div>
      <div class="stat-card fade-up">
        <span class="stat-bg-num">6</span>
        <div class="stat-icon">
          <img loading="lazy" decoding="async" src="/logos/confianza/Centro de Capacitación Autorizado.webp" alt="" />
        </div>
        <span class="stat-num stat-num--text">ATC</span>
        <span class="stat-label">Centro de Capacitación Autorizado</span>
        <p class="stat-desc">Centro certificado de entrenamiento y certificación profesional.</p>
      </div>
    </div>
  </section>

  <!-- Marcas -->
  <section class="marcas" id="marcas">
    <div class="section-header marcas-header fade-up">
      <h2>Marcas que representamos</h2>
    </div>
    <div class="marcas-logos fade-up">
      <div class="marca-item">
        <img src="/logos/autodesk_partner.webp" alt="Autodesk Gold Partner" loading="lazy" decoding="async" />
      </div>
      <div class="marca-item">
        <img src="/logos/ansys_partner.webp" alt="Ansys ESSS Partner" loading="lazy" decoding="async" />
      </div>
      <div class="marca-item">
        <img src="/logos/oracle_partner.webp" alt="Oracle Partner" loading="lazy" decoding="async" />
      </div>
    </div>
  </section>

  <!-- Portales de conocimiento -->
  <section class="portales" id="portales">
    <div class="section-header fade-up">

      <h2>Recursos especializados</h2>
      <p class="section-desc">Accede a contenido técnico de alta calidad en nuestros portales especializados.</p>
    </div>
    <div class="portales-grid">
      <div class="portal-card fade-up">
        <div class="portal-img">
          <img src="/portales/blog-prototicad.webp" alt="Prototicad3D" loading="lazy" decoding="async" />
        </div>
        <div class="portal-content">
          <img src="/portales/prototicad3d.png" alt="Prototicad3D Logo" class="portal-logo" />
          <h3>Prototicad3D</h3>
          <p>Contenido especializado en desarrollo de productos, manufactura e innovación tecnológica.</p>
          <a href="https://prototicad3d.com" target="_blank" rel="noopener" class="portal-link">Visitar portal <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14L21 3"/></svg></a>
        </div>
      </div>
      <div class="portal-card fade-up">
        <div class="portal-img">
          <img src="/portales/blog-cadbim.webp" alt="CadBim3D" loading="lazy" decoding="async" />
        </div>
        <div class="portal-content">
          <img src="/portales/cadbim3d.png" alt="CadBim3D Logo" class="portal-logo" />
          <h3>CadBim3D</h3>
          <p>Recursos de arquitectura, ingeniería y construcción con enfoque en tecnología BIM.</p>
          <a href="https://cadbim3d.com" target="_blank" rel="noopener" class="portal-link">Visitar portal <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14L21 3"/></svg></a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style is:inline>
  /* Hero Slider */
  .hero {
    position: relative;
    height: 100vh;
    background-color: #0a0f1a;
    color: var(--white);
    overflow: hidden;
  }

  .hero-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.8s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
    display: flex;
    flex-direction: column;
  }

  .hero-slide--active {
    opacity: 1;
    pointer-events: auto;
  }

  .hero-bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(10, 15, 26, 0.45) 0%, rgba(10, 15, 26, 0.65) 50%, rgba(10, 15, 26, 0.9) 100%),
      radial-gradient(ellipse 80% 60% at 70% 50%, rgba(30, 80, 160, 0.12) 0%, transparent 70%);
    pointer-events: none;
    z-index: 1;
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 2rem;
    height: 100%;
    gap: 2rem;
  }

  /* Event slide */
  .hero-inner--event {
    grid-template-columns: 1.2fr 0.8fr;
    gap: 2rem;
    align-items: center;
    margin-top: -30px;
  }

  .hero-inner--event h1 {
    font-size: 2.4rem;
  }

  .event-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: rgba(255, 107, 53, 0.12);
    color: var(--white);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    padding: 0.5rem 1.2rem;
    border-radius: 100px;
    border: 1px solid rgba(255, 107, 53, 0.25);
    margin-bottom: 1.2rem;
    margin-left: -0.15rem;
  }

  .event-live {
    background: #e53935;
    color: var(--white);
    font-size: 0.7rem;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    letter-spacing: 1px;
    animation: live-pulse 2s ease-in-out infinite;
  }

  @keyframes live-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.6; }
  }

  .event-pre {
    font-size: 1.05rem;
    font-weight: 900;
    color: var(--orange);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 0.5rem;
    font-family: 'Montserrat', system-ui, sans-serif;
    font-weight: 900;
    font-size: 1.4rem;
    -webkit-text-stroke: 0.5px currentColor;
  }

  .hero-subtitle--event {
    max-width: 700px;
    font-size: 1.05rem;
  }

  .event-details {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .event-detail {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.92rem;
    color: rgba(255, 255, 255, 0.85);
    font-weight: 500;
  }

  .event-detail svg {
    color: var(--orange);
    flex-shrink: 0;
  }

  .hero-event-img {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .hero-event-img img {
    width: 100%;
    max-width: 480px;
  }

  .hero-event-img .event-reflection {
    width: 100%;
    max-width: 480px;
    height: 60px;
    object-fit: cover;
    object-position: bottom;
    transform: scaleY(-1);
    opacity: 0.12;
    mask-image: linear-gradient(to bottom, rgba(0,0,0,0.4), transparent);
    -webkit-mask-image: linear-gradient(to bottom, rgba(0,0,0,0.4), transparent);
    pointer-events: none;
    margin-top: -1px;
  }

  /* Slider controls */
  .slider-dots {
    position: absolute;
    bottom: 5.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    display: flex;
    gap: 0.5rem;
  }

  .slider-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.4);
    background: transparent;
    cursor: pointer;
    transition: all 0.3s ease;
    padding: 0;
  }

  .slider-dot--active {
    background: var(--orange);
    border-color: var(--orange);
    transform: scale(1.2);
  }

  .slider-dot:hover {
    border-color: var(--white);
  }

  .slider-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: var(--white);
    width: 48px;
    height: 48px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .slider-arrow:hover {
    background: rgba(255, 107, 53, 0.2);
    border-color: rgba(255, 107, 53, 0.4);
    transform: translateY(-50%) scale(1.1);
  }

  .slider-arrow--left { left: 1.5rem; }
  .slider-arrow--right { right: 1.5rem; }

  .hero-text {
    text-align: left;
  }

  .hero h1 {
    font-size: 3.2rem;
    font-weight: 800;
    color: var(--white);
    margin-bottom: 1.5rem;
    line-height: 1.15;
    letter-spacing: -0.5px;
  }

  .hero-subtitle {
    font-size: 1.1rem;
    color: rgba(176, 190, 197, 0.9);
    margin-bottom: 2.5rem;
    line-height: 1.8;
    max-width: 500px;
  }

  .hero-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .cta-primary {
    display: inline-block;
    background: var(--orange);
    color: var(--white);
    padding: 0.95rem 2.2rem;
    border-radius: var(--radius);
    font-weight: 600;
    font-size: 1rem;
    transition: all 0.3s ease;
    border: 2px solid var(--orange);
  }

  .cta-primary:hover {
    background: var(--orange-hover);
    border-color: var(--orange-hover);
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(255, 107, 53, 0.3);
  }

  .cta-secondary {
    display: inline-block;
    background: transparent;
    color: var(--white);
    padding: 0.95rem 2.2rem;
    border-radius: var(--radius);
    font-weight: 600;
    font-size: 1rem;
    border: 2px solid rgba(255, 255, 255, 0.3);
    transition: all 0.3s ease;
  }

  .cta-secondary:hover {
    border-color: var(--white);
    background: rgba(255, 255, 255, 0.08);
    transform: translateY(-2px);
  }

  /* Globe visual */
  .hero-visual {
    position: relative;
    width: 100%;
    height: 420px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .globe {
    position: relative;
    width: 180px;
    height: 180px;
  }

  .globe-logo {
    width: 140px;
    height: auto;
    object-fit: contain;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    filter: drop-shadow(0 0 30px rgba(255, 107, 53, 0.4)) drop-shadow(0 0 60px rgba(255, 107, 53, 0.15));
    animation: globe-pulse 4s ease-in-out infinite;
    will-change: opacity;
  }

  .globe-ring {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 260px;
    height: 260px;
    transform: translate(-50%, -50%);
    border: 1.5px solid rgba(100, 160, 255, 0.15);
    border-radius: 50%;
    animation: ring-rotate 20s linear infinite;
    will-change: transform;
  }

  .globe-ring-icon {
    position: absolute;
    top: -28px;
    left: 50%;
    transform: translateX(-50%);
    width: 56px;
    height: 56px;
    object-fit: contain;
    filter: drop-shadow(0 0 8px rgba(255, 107, 53, 0.6));
    animation: ring-rotate-counter 20s linear infinite;
  }

  @keyframes ring-rotate-counter {
    from { transform: translateX(-50%) rotate(0deg); }
    to { transform: translateX(-50%) rotate(-360deg); }
  }

  @keyframes globe-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.75; }
  }

  @keyframes ring-rotate {
    from { transform: translate(-50%, -50%) rotate(0deg); }
    to { transform: translate(-50%, -50%) rotate(360deg); }
  }

  /* Orbit cards */
  .orbit-card {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255, 255, 255, 0.07);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 12px;
    padding: 0.6rem 1rem;
    color: var(--white);
    font-size: 0.85rem;
    font-weight: 600;
    transition: all 0.3s ease;
    animation: float 6s ease-in-out infinite;
    will-change: transform;
    white-space: nowrap;
  }

  .orbit-card:hover {
    background: rgba(255, 255, 255, 0.15);
    border-color: rgba(255, 107, 53, 0.4);
    transform: scale(1.08);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
  }

  .orbit-logo {
    height: 36px;
    width: auto;
    object-fit: contain;
  }

  .orbit-1 { top: 5%; left: 55%; animation-delay: 0s; }
  .orbit-2 { top: 22%; right: 2%; animation-delay: -1s; }
  .orbit-3 { bottom: 22%; right: 5%; animation-delay: -2s; }
  .orbit-4 { bottom: 8%; left: 38%; animation-delay: -3s; }
  .orbit-5 { top: 50%; left: 5%; animation-delay: -4.5s; }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }

  /* Scroll indicator */
  .scroll-indicator {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, rgba(255, 255, 255, 0.4), transparent);
    animation: scroll-anim 2s ease-in-out infinite;
  }

  @keyframes scroll-anim {
    0%, 100% { opacity: 0.3; transform: scaleY(0.6); }
    50% { opacity: 1; transform: scaleY(1); }
  }

  /* ===== Section Common ===== */
  .section-header {
    text-align: center;
    max-width: 680px;
    margin: 0 auto 3.5rem;
  }

  .section-tag {
    display: inline-block;
    background: linear-gradient(135deg, rgba(255, 107, 53, 0.1), rgba(255, 107, 53, 0.05));
    color: var(--orange);
    font-size: 0.82rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    padding: 0.4rem 1.2rem;
    border-radius: 100px;
    margin-bottom: 1rem;
    border: 1px solid rgba(255, 107, 53, 0.15);
  }

  .section-tag--light {
    background: rgba(255, 255, 255, 0.1);
    color: var(--white);
    border-color: rgba(255, 255, 255, 0.15);
  }

  .section-header h2 {
    font-size: 2.4rem;
    font-weight: 800;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .section-desc {
    font-size: 1.05rem;
    color: var(--gray-600);
    line-height: 1.7;
  }

  /* ===== Servicios ===== */
  .servicios {
    padding: 6rem 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .servicios-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.8rem;
  }

  .servicio-card {
    display: block;
    border-radius: 12px;
    overflow: hidden;
    background: var(--white);
    border: 1px solid var(--gray-200);
    transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    position: relative;
  }

  .servicio-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.12);
    border-color: transparent;
  }

  .servicio-img {
    position: relative;
    height: 200px;
    overflow: hidden;
  }

  .servicio-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .servicio-card:hover .servicio-img img {
    transform: scale(1.08);
  }

  .servicio-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 40%, rgba(26, 35, 50, 0.6) 100%);
    pointer-events: none;
  }

  .servicio-content {
    padding: 1.5rem;
  }

  .servicio-content h3 {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .servicio-content p {
    font-size: 0.9rem;
    color: var(--gray-600);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .servicio-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--orange);
    transition: gap 0.3s ease;
  }

  .servicio-card:hover .servicio-link {
    gap: 0.8rem;
  }

  /* ===== Especializaciones ===== */
  .especializaciones {
    padding: 6rem 2rem;
    background: var(--gray-50);
    content-visibility: auto;
    contain-intrinsic-size: auto 800px;
  }

  .espec-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .espec-card {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    min-height: 410px;
    display: flex;
    align-items: flex-end;
    cursor: pointer;
    transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94), box-shadow 0.5s ease;
  }

  .espec-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.25);
  }

  .espec-card-bg {
    position: absolute;
    inset: 0;
    background: var(--bg) center/cover no-repeat;
    transition: transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94), filter 0.8s ease;
    transform: scaleX(var(--bg-flip, 1));
  }


  .espec-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(26, 35, 50, 0.05) 0%, rgba(26, 35, 50, 0.5) 40%, rgba(26, 35, 50, 0.9) 100%);
    z-index: 1;
    transition: background 0.5s ease;
  }

  .espec-card:hover::after {
    background: linear-gradient(180deg, rgba(255, 107, 53, 0.05) 0%, rgba(26, 35, 50, 0.4) 40%, rgba(26, 35, 50, 0.92) 100%);
  }

  .espec-card:hover .espec-card-bg {
    transform: scaleX(var(--bg-flip, 1)) scale(1.12);
    filter: brightness(1.1);
  }

  .espec-card-content {
    position: relative;
    z-index: 2;
    padding: 2rem 1.5rem;
    color: var(--white);
    transform: translateY(10px);
    transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .espec-card:hover .espec-card-content {
    transform: translateY(0);
  }

  .espec-badge {
    display: inline-block;
    background: var(--orange);
    color: var(--white);
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    margin-bottom: 0.75rem;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .espec-card:hover .espec-badge {
    transform: scale(1.05);
    box-shadow: 0 4px 15px rgba(255, 107, 53, 0.4);
  }

  .espec-card-content h3 {
    color: var(--white);
    font-size: 1.3rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .espec-card-content p {
    font-size: 0.88rem;
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.5;
    margin-bottom: 1.2rem;
  }

  .espec-btn {
    display: inline-block;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(8px);
    color: var(--white);
    padding: 0.55rem 1.4rem;
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 600;
    border: 1px solid rgba(255, 255, 255, 0.25);
    transition: all 0.3s ease;
  }

  .espec-btn:hover {
    background: var(--orange);
    border-color: var(--orange);
    box-shadow: 0 4px 15px rgba(255, 107, 53, 0.3);
    transform: translateY(-2px);
  }

  /* ===== ¿Por qué elegirnos? ===== */
  .porque {
    position: relative;
    padding: 6rem 2rem;
    overflow: hidden;
    color: var(--white);
  }

  .porque-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #0f1923 0%, #1a2332 50%, #1e3a5f 100%);
    z-index: 0;
  }

  .porque-bg::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(255, 107, 53, 0.08) 0%, transparent 70%);
    border-radius: 50%;
  }

  .porque-inner {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    margin: 0 auto;
  }

  .porque .section-header h2 {
    color: var(--white);
  }

  .porque-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1.5rem;
  }

  .porque-card {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    padding: 2rem 1.3rem;
    text-align: center;
    transition: all 0.4s ease;
  }

  .porque-card:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 107, 53, 0.3);
    transform: translateY(-4px);
  }

  .porque-icon {
    width: 56px;
    height: 56px;
    margin: 0 auto 1.2rem;
    color: var(--orange);
  }

  .porque-icon svg {
    width: 100%;
    height: 100%;
  }

  .porque-card h3 {
    color: var(--white);
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 0.6rem;
    line-height: 1.3;
  }

  .porque-card p {
    font-size: 0.85rem;
    color: rgba(176, 190, 197, 0.85);
    line-height: 1.6;
  }

  /* ===== Estadísticas ===== */
  .stats-section {
    padding: 5rem 2rem;
    background: var(--white);
    content-visibility: auto;
    contain-intrinsic-size: auto 700px;
  }

  .stats-header {
    text-align: center;
    max-width: 620px;
    margin: 0 auto 3rem;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    max-width: 1100px;
    margin: 0 auto;
    background: var(--gray-200);
    border: 1px solid var(--gray-200);
    border-radius: 16px;
    overflow: hidden;
  }

  .stat-card {
    background: var(--white);
    padding: 2.5rem 2rem;
    text-align: center;
    transition: all 0.4s ease;
    position: relative;
    overflow: hidden;
  }

  .stat-card:hover {
    background: var(--white);
  }

  /* Background number (outline style) */
  .stat-bg-num {
    position: absolute;
    top: 0.3rem;
    left: 1rem;
    font-size: 5.5rem;
    font-weight: 900;
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 1.5px rgba(255, 107, 53, 0.1);
    pointer-events: none;
    transition: all 0.4s ease;
    user-select: none;
  }

  .stat-card:hover .stat-bg-num {
    -webkit-text-stroke: 1.5px rgba(255, 107, 53, 0.22);
    transform: scale(1.05);
  }

  /* Icon */
  .stat-icon {
    width: 56px;
    height: 56px;
    margin: 0 auto 1.2rem;
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .stat-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .stat-card:hover .stat-icon {
    transform: scale(1.2);
  }

  /* Number */
  .stat-num {
    display: block;
    font-size: 3rem;
    font-weight: 900;
    color: var(--orange);
    -webkit-text-stroke: 1px var(--orange);
    line-height: 1;
    margin-bottom: 0.4rem;
    cursor: default;
  }

  .stat-label {
    font-weight: 800;
  }

  .stat-label {
    display: block;
    font-size: 0.88rem;
    font-weight: 800;
    color: var(--navy);
    margin-bottom: 0.5rem;
  }

  .stat-desc {
    font-size: 0.82rem;
    color: var(--gray-600);
    line-height: 1.5;
  }

  /* ===== Marcas ===== */
  .marcas {
    padding: 2.5rem 2rem 2rem;
    background: var(--gray-50);
    content-visibility: auto;
    contain-intrinsic-size: auto 300px;
  }

  .marcas-header {
    margin-bottom: 1.5rem;
  }

  .marcas-header h2 {
    font-size: 1.6rem;
    font-weight: 400;
  }

  .marcas-logos {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 3rem;
    max-width: 650px;
    margin: 0 auto;
  }

  .marca-item {
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.3s ease;
  }

  .marca-item:hover {
    opacity: 0.7;
  }

  .marca-item img {
    height: 89px;
    width: auto;
    object-fit: contain;
  }

  /* ===== Portales ===== */
  .portales {
    padding: 6rem 2rem;
    max-width: 1200px;
    margin: 0 auto;
    content-visibility: auto;
    contain-intrinsic-size: auto 500px;

  }

  .portales-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  .portal-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-radius: 16px;
    overflow: hidden;
    background: var(--white);
    border: 1px solid var(--gray-200);
    transition: all 0.4s ease;
  }

  .portal-card:hover {
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.1);
    transform: translateY(-4px);
  }

  .portal-img {
    height: 100%;
    min-height: 240px;
  }

  .portal-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .portal-content {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .portal-logo {
    height: 28px;
    width: auto;
    object-fit: contain;
    margin-bottom: 0.75rem;
  }

  .portal-content h3 {
    font-size: 1.3rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .portal-content p {
    font-size: 0.9rem;
    color: var(--gray-600);
    line-height: 1.6;
    margin-bottom: 1.2rem;
  }

  .portal-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--orange);
    font-weight: 600;
    font-size: 0.9rem;
    transition: gap 0.3s ease;
  }

  .portal-link:hover {
    gap: 0.7rem;
  }

  /* ===== CTA Contacto ===== */
  .cta-contacto {
    background: linear-gradient(135deg, var(--orange) 0%, #e85a25 50%, #c44a1a 100%);
    padding: 5rem 2rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .cta-contacto::before {
    content: '';
    position: absolute;
    top: -100px;
    right: -100px;
    width: 400px;
    height: 400px;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 50%;
  }

  .cta-contacto::after {
    content: '';
    position: absolute;
    bottom: -150px;
    left: -100px;
    width: 500px;
    height: 500px;
    background: rgba(255, 255, 255, 0.03);
    border-radius: 50%;
  }

  .cta-contacto-inner {
    position: relative;
    z-index: 1;
    max-width: 700px;
    margin: 0 auto;
  }

  .cta-contacto h2 {
    color: var(--white);
    font-size: 2.2rem;
    font-weight: 800;
    margin-bottom: 1rem;
  }

  .cta-contacto p {
    color: rgba(255, 255, 255, 0.9);
    font-size: 1.1rem;
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .cta-buttons {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }

  .cta-contacto .cta-primary {
    background: var(--white);
    color: var(--orange);
    border-color: var(--white);
  }

  .cta-contacto .cta-primary:hover {
    background: var(--gray-50);
    border-color: var(--gray-50);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.2);
  }

  .cta-contacto .cta-secondary {
    border-color: rgba(255, 255, 255, 0.5);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .cta-contacto .cta-secondary:hover {
    border-color: var(--white);
    background: rgba(255, 255, 255, 0.1);
  }

  .cta-info {
    display: flex;
    justify-content: center;
    gap: 2.5rem;
    flex-wrap: wrap;
  }

  .cta-info-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.85);
  }

  /* ===== Animations ===== */
  .fade-up {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .fade-up.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ===== Responsive ===== */
  @media (max-width: 1100px) {
    .espec-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .porque-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

