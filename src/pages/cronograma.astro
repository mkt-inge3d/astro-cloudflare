<style>
  /* Hero (from CoursePage) */
  .cp-hero{position:relative;min-height:320px;display:flex;align-items:flex-end;overflow:hidden}
  .cp-hero-bg{position:absolute;inset:0;background:linear-gradient(135deg,#0f1923,#1a2332 50%,#1e3a5f);z-index:0}
  .cp-hero-bg::before{content:'';position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,.06) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.06) 1px,transparent 1px),linear-gradient(rgba(255,255,255,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.03) 1px,transparent 1px);background-size:60px 60px,60px 60px,15px 15px,15px 15px}
  .cp-hero-bg::after{content:'';position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(255,107,53,.3),transparent)}
  .cp-hero-inner{position:relative;z-index:1;max-width:1200px;margin:0 auto;padding:7rem 2rem 3rem;width:100%}
  .cp-breadcrumb{display:flex;align-items:center;gap:.5rem;font-size:.85rem;color:rgba(176,190,197,.7);margin-bottom:1.5rem;flex-wrap:wrap}
  .cp-breadcrumb a{color:rgba(176,190,197,.7);transition:color .3s}.cp-breadcrumb a:hover{color:var(--orange)}
  .cp-breadcrumb svg{opacity:.4}.cp-breadcrumb span{color:#fff}
  .cp-badge{display:inline-block;background:rgba(255,107,53,.12);color:var(--orange);font-size:.78rem;font-weight:700;text-transform:uppercase;letter-spacing:2px;padding:.4rem 1rem;border-radius:100px;border:1px solid rgba(255,107,53,.2);margin-bottom:1rem}
  .cp-hero-content h1{font-size:2.5rem;font-weight:800;color:#fff;margin-bottom:1rem;line-height:1.15}
  .cp-hero-content>p{font-size:1.1rem;color:rgba(176,190,197,.85);max-width:650px;line-height:1.7}

  /* Section headings */
  .cp-section{margin-bottom:2.5rem}
  .cp-section h2{font-size:1.5rem;font-weight:800;margin-bottom:1rem;padding-bottom:.75rem;border-bottom:2px solid var(--gray-200);position:relative}
  .cp-section h2::after{content:'';position:absolute;bottom:-2px;left:0;width:60px;height:2px;background:var(--orange)}

  /* Sidebar (from CoursePage) */
  .cp-sidebar{position:sticky;top:80px;display:flex;flex-direction:column;gap:1.2rem}
  .cp-sidebar-card{background:var(--white);border:1px solid var(--gray-200);border-radius:12px;padding:1.5rem;transition:all .3s}
  .cp-sidebar-card:hover{box-shadow:0 6px 20px rgba(0,0,0,.06)}
  .cp-sidebar-enroll{border-color:rgba(255,107,53,.2);background:linear-gradient(135deg,rgba(255,107,53,.03),transparent)}
  .cp-sidebar-icon{width:32px;height:32px;color:var(--orange);margin-bottom:.6rem}
  .cp-sidebar-icon svg{width:100%;height:100%}
  .cp-sidebar-card h3{font-size:1rem;font-weight:700;margin-bottom:.75rem}
  .cp-sidebar-card p{font-size:.85rem;color:var(--gray-600);line-height:1.5;margin-bottom:.5rem}
  .cp-enroll-btn{display:block;text-align:center;background:var(--orange);color:#fff;padding:.75rem;border-radius:8px;font-weight:600;font-size:.92rem;transition:all .3s;margin-top:.5rem;text-decoration:none}
  .cp-enroll-btn:hover{background:var(--orange-hover);transform:translateY(-1px)}
  .cp-contact-lines{display:flex;flex-direction:column;gap:.3rem}
  .cp-contact-lines a{font-size:.85rem;color:var(--orange);font-weight:600;transition:opacity .3s}
  .cp-contact-lines a:hover{opacity:.8}
  .cp-license-link{display:block;font-size:.88rem;color:var(--orange);font-weight:600;transition:opacity .3s}
  .cp-license-link:hover{opacity:.8}

  /* CTA */
  .cp-cta{background:linear-gradient(135deg,var(--orange),#e85a25 50%,#c44a1a);padding:4rem 2rem;text-align:center;position:relative;overflow:hidden}
  .cp-cta::before{content:'';position:absolute;top:-80px;right:-80px;width:300px;height:300px;background:rgba(255,255,255,.05);border-radius:50%}
  .cp-cta-inner{position:relative;z-index:1;max-width:550px;margin:0 auto}
  .cp-cta h2{color:#fff;font-size:1.8rem;font-weight:800;margin-bottom:.75rem}
  .cp-cta p{color:rgba(255,255,255,.9);font-size:1rem;line-height:1.6;margin-bottom:1.5rem}
  .cp-cta-btn{display:inline-block;background:#fff;color:var(--orange);padding:.9rem 2.5rem;border-radius:8px;font-weight:600;font-size:.95rem;transition:all .3s;border:2px solid #fff;text-decoration:none}
  .cp-cta-btn:hover{background:var(--gray-50);transform:translateY(-2px);box-shadow:0 8px 25px rgba(0,0,0,.2)}

  /* Fade animation */
  .fade-up{opacity:0;transform:translateY(30px);transition:opacity .7s cubic-bezier(.25,.46,.45,.94),transform .7s cubic-bezier(.25,.46,.45,.94)}
  .fade-up.visible{opacity:1;transform:translateY(0)}

  /* Cronograma-specific styles */
  .cr-layout{display:grid;grid-template-columns:1fr 320px;gap:3rem;max-width:1200px;margin:0 auto;padding:3rem 2rem 4rem;align-items:start}
  .cr-main{min-width:0}

  .cr-program{border:1px solid var(--gray-200);border-radius:12px;overflow:hidden;transition:all .3s;margin-bottom:.75rem}
  .cr-program:hover{border-color:rgba(255,107,53,.2)}
  .cr-program[open]{border-color:rgba(255,107,53,.3);box-shadow:0 6px 25px rgba(0,0,0,.06)}

  .cr-program-header{display:flex;align-items:center;justify-content:space-between;padding:1.2rem 1.5rem;cursor:pointer;list-style:none;transition:background .2s;gap:1rem}
  .cr-program-header::-webkit-details-marker{display:none}
  .cr-program-header:hover{background:var(--gray-50)}
  .cr-program-info{flex:1;min-width:0}
  .cr-program-info h3{font-size:1rem;font-weight:700;color:var(--navy);margin-bottom:.4rem}
  .cr-program-meta{display:flex;gap:.5rem;flex-wrap:wrap}
  .cr-meta-tag{font-size:.78rem;font-weight:600;color:var(--gray-600);background:var(--gray-50);border:1px solid var(--gray-200);padding:.2rem .6rem;border-radius:6px}
  .cr-meta-price{border-color:rgba(255,107,53,.15);background:rgba(255,107,53,.04)}
  .cr-meta-price strong{color:var(--orange)}
  .cr-old{text-decoration:line-through;color:var(--gray-400);font-weight:400;font-size:.75rem;margin-right:.25rem}
  .cr-chevron{color:var(--gray-400);transition:transform .3s;flex-shrink:0}
  .cr-program[open] .cr-chevron{transform:rotate(180deg);color:var(--orange)}

  /* Dark header for specializations */
  .cr-program--dark>.cr-program-header{background:linear-gradient(135deg,#0f1923,#1a2332 50%,#1e3a5f);border-radius:11px 11px 0 0}
  .cr-program--dark:not([open])>.cr-program-header{border-radius:11px}
  .cr-program--dark>.cr-program-header:hover{background:linear-gradient(135deg,#141e2b,#1f2b3d 50%,#234568)}
  .cr-program--dark .cr-program-info h3{color:#fff}
  .cr-program--dark .cr-meta-tag{background:rgba(255,255,255,.08);border-color:rgba(255,255,255,.12);color:rgba(255,255,255,.8)}
  .cr-program--dark .cr-meta-price{background:rgba(255,107,53,.12);border-color:rgba(255,107,53,.25)}
  .cr-program--dark .cr-meta-price strong{color:var(--orange)}
  .cr-program--dark .cr-old{color:rgba(255,255,255,.4)}
  .cr-program--dark .cr-chevron{color:rgba(255,255,255,.5)}
  .cr-program--dark[open] .cr-chevron{color:var(--orange)}
  .cr-program--dark{border-color:rgba(255,107,53,.15)}
  .cr-program--dark[open]{border-color:rgba(255,107,53,.3)}

  .cr-program-body{padding:0 1.5rem 1.5rem;border-top:1px solid var(--gray-100)}

  .cr-table{width:100%;border-collapse:collapse;margin-top:1rem;font-size:.88rem}
  .cr-table thead{background:var(--gray-50)}
  .cr-table th{text-align:left;padding:.6rem .8rem;font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--gray-500);border-bottom:2px solid var(--gray-200)}
  .cr-table td{padding:.75rem .8rem;border-bottom:1px solid var(--gray-100);color:var(--gray-700);vertical-align:top}
  .cr-table td:first-child{font-weight:600;color:var(--navy)}
  .cr-table td:first-child a{color:var(--navy);text-decoration:none;transition:color .2s;border-bottom:1px solid transparent}
  .cr-table td:first-child a:hover{color:var(--orange);border-bottom-color:var(--orange)}
  .cr-table td:nth-child(2){white-space:nowrap;color:var(--orange);font-weight:600}
  .cr-table td:nth-child(3){font-size:.82rem;color:var(--gray-600);white-space:nowrap}
  .cr-table td:nth-child(4){white-space:nowrap}
  .cr-table tbody tr:hover{background:rgba(255,107,53,.02)}
  .cr-table tbody tr:last-child td{border-bottom:none}
  .cr-price-cell{color:var(--orange);font-size:.9rem}

  .cr-program-actions{display:flex;gap:.75rem;margin-top:1.25rem;flex-wrap:wrap}
  .cr-btn{display:inline-block;background:var(--orange);color:#fff;padding:.6rem 1.5rem;border-radius:8px;font-weight:700;font-size:.85rem;transition:all .3s;text-decoration:none}
  .cr-btn:hover{background:var(--orange-hover);transform:translateY(-1px);box-shadow:0 4px 15px rgba(255,107,53,.3)}
  .cr-btn-outline{display:inline-block;border:1px solid var(--gray-200);color:var(--navy);padding:.6rem 1.5rem;border-radius:8px;font-weight:600;font-size:.85rem;transition:all .3s;text-decoration:none}
  .cr-btn-outline:hover{border-color:var(--orange);color:var(--orange)}

  .cr-includes-list{list-style:none;padding:0;display:flex;flex-direction:column;gap:.35rem}
  .cr-includes-list li{font-size:.84rem;color:var(--gray-600);padding-left:1.3rem;position:relative;line-height:1.5}
  .cr-includes-list li::before{content:'';position:absolute;left:0;top:7px;width:8px;height:8px;border-radius:50%;background:var(--orange)}

  @media(max-width:1024px){.cr-layout{grid-template-columns:1fr}.cp-sidebar{position:static;display:grid;grid-template-columns:1fr 1fr;gap:1rem}}
  @media(max-width:600px){.cr-table{font-size:.82rem}.cr-table th,.cr-table td{padding:.5rem .4rem}.cr-program-header{padding:1rem}.cp-hero-content h1{font-size:1.8rem}.cp-hero-inner{padding:6rem 1.5rem 2.5rem}.cp-sidebar{grid-template-columns:1fr}}
</style>

<script is:inline>
const o=new IntersectionObserver(e=>{e.forEach(e=>{if(e.isIntersecting){const p=e.target.parentElement;if(p){const s=Array.from(p.querySelectorAll('.fade-up'));const i=s.indexOf(e.target);setTimeout(()=>e.target.classList.add('visible'),i>=0?i*80:0)}else e.target.classList.add('visible');o.unobserve(e.target)}})},{threshold:.1,rootMargin:'0px 0px -50px 0px'});
document.querySelectorAll('.fade-up').forEach(e=>o.observe(e));
</script>
