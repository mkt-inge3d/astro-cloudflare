---
import Layout from '../../../layouts/Layout.astro';

const aecProducts = [
  { name: 'AutoCAD', logo: '/logos/autocad-full.png', href: '/licencias/autodesk/autocad', desc: 'Software de diseño 2D y 3D líder en la industria.' },
  { name: 'Revit', logo: '/logos/revit-full.png', href: '/licencias/autodesk/revit', desc: 'Modelado BIM para arquitectura, estructura e instalaciones.' },
  { name: 'Civil 3D', logo: '/logos/civil-3d.png', href: '/licencias/autodesk/civil-3d', desc: 'Diseño y documentación de ingeniería civil.' },
  { name: 'Navisworks', logo: '/logos/navisworks.png', href: '/licencias/autodesk/navisworks', desc: 'Coordinación, revisión y simulación de modelos.' },
  { name: 'Robot Structural', logo: '/logos/revit-full.png', href: '/licencias/autodesk/robot-structural', desc: 'Análisis y diseño estructural avanzado.' },
  { name: 'Advance Steel', logo: '/logos/advance-steel.png', href: '/licencias/autodesk/advance-steel', desc: 'Modelado y detallado de estructuras metálicas.' },
  { name: 'InfraWorks', logo: '/logos/infraworks.png', href: '/licencias/autodesk/infraworks', desc: 'Diseño conceptual de infraestructura.' },
  { name: 'Construction Cloud', logo: '/logos/autocad-full.png', href: '/licencias/autodesk/construction-cloud', desc: 'Plataforma de gestión de construcción en la nube.' },
  { name: '3ds Max', logo: '/logos/3ds-max.png', href: '/licencias/autodesk/3ds-max', desc: 'Modelado, animación y renderizado 3D.' },
];

const mfgProducts = [
  { name: 'Inventor', logo: '/logos/inventor-full.png', href: '/licencias/autodesk/inventor', desc: 'Diseño mecánico 3D y simulación de productos.' },
  { name: 'AutoCAD Plant 3D', logo: '/logos/plant-3d.png', href: '/licencias/autodesk/autocad-plant-3d', desc: 'Diseño de plantas industriales y tuberías.' },
  { name: 'AutoCAD Electrical', logo: '/logos/autocad-electrical.png', href: '/licencias/autodesk/autocad-electrical', desc: 'Diseño de sistemas de control eléctrico.' },
  { name: 'Fusion', logo: '/logos/inventor-full.png', href: '/licencias/autodesk/fusion', desc: 'CAD/CAM/CAE unificado en la nube.' },
  { name: 'Inventor Nastran', logo: '/logos/inventor-full.png', href: '/licencias/autodesk/inventor-nastran', desc: 'Simulación FEA integrada en Inventor.' },
  { name: 'Inventor CAM', logo: '/logos/inventor-full.png', href: '/licencias/autodesk/inventor-cam', desc: 'Manufactura asistida por computadora.' },
];
---

<Layout title="Licencias Individuales Autodesk | SemcoCAD" description="Adquiere licencias individuales de software Autodesk: AutoCAD, Revit, Civil 3D, Inventor y más. Suscripciones anuales y trianuales con soporte local.">

  <!-- Hero -->
  <section class="ad-hero">
    <div class="ad-hero-bg"></div>
    <div class="ad-hero-inner">
      <nav class="breadcrumb fade-up">
        <a href="/">Home</a>
        <svg width="6" height="10" viewBox="0 0 6 10" fill="none"><path d="M1 1l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        <a href="/licencias">Licencias</a>
        <svg width="6" height="10" viewBox="0 0 6 10" fill="none"><path d="M1 1l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        <span>Autodesk</span>
      </nav>
      <div class="ad-hero-content fade-up">
        <span class="ad-badge">Autodesk Gold Partner</span>
        <h1>Licencias Individuales Autodesk</h1>
        <p>Cualquiera sea su sector o industria, las soluciones de software Autodesk que brindamos le permitirán potenciar sus proyectos de diseño, ingeniería y construcción.</p>
        <div class="ad-hero-actions">
          <a href="/contacto" class="btn-primary">Solicitar cotización</a>
          <a href="#productos" class="btn-secondary">Ver productos</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Intro / Subscription model -->
  <section class="ad-intro">
    <div class="ad-intro-inner">
      <div class="ad-intro-text fade-up">
        <h2>¿Qué es una suscripción Autodesk?</h2>
        <p>Las suscripciones Autodesk se activan mediante un plan de suscripción, el cual proporciona el acceso al software contratado a usuarios designados por un periodo de tiempo. Es la única forma vigente para acceder al software Autodesk.</p>
        <p>Puedes adquirir suscripciones de <strong>1 año o 3 años</strong>, con flexibilidad de renovación. Los planes de 3 años ofrecen un precio fijo garantizado durante todo el periodo.</p>
      </div>
      <div class="ad-intro-includes fade-up">
        <h3>Tu suscripción incluye</h3>
        <div class="includes-grid">
          <div class="include-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            <div>
              <strong>Actualizaciones</strong>
              <span>Últimas versiones siempre disponibles</span>
            </div>
          </div>
          <div class="include-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
            <div>
              <strong>3 versiones previas</strong>
              <span>Acceso a las 3 versiones anteriores</span>
            </div>
          </div>
          <div class="include-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
            <div>
              <strong>25 GB en la nube</strong>
              <span>Almacenamiento en Autodesk Drive</span>
            </div>
          </div>
          <div class="include-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            <div>
              <strong>Uso remoto</strong>
              <span>Trabaja desde casa o en viaje</span>
            </div>
          </div>
          <div class="include-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
            <div>
              <strong>Administración fácil</strong>
              <span>Gestión centralizada de usuarios</span>
            </div>
          </div>
          <div class="include-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <div>
              <strong>Precio fijo 3 años</strong>
              <span>Bloquea tu tarifa con plan trianual</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Products AEC -->
  <section class="ad-products" id="productos">
    <div class="ad-products-inner">
      <div class="section-header fade-up">
        <span class="ad-section-tag">Productos</span>
        <h2>Arquitectura, Ingeniería y Construcción</h2>
        <p>Software especializado para proyectos AEC de cualquier escala.</p>
      </div>
      <div class="products-grid">
        {aecProducts.map((product) => (
          <a href={product.href} class="product-card fade-up">
            <div class="product-card-logo">
              <img src={product.logo} alt={product.name} loading="lazy" />
            </div>
            <div class="product-card-info">
              <h3>{product.name}</h3>
              <p>{product.desc}</p>
            </div>
            <span class="product-card-arrow">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Products MFG -->
  <section class="ad-products ad-products--alt">
    <div class="ad-products-inner">
      <div class="section-header fade-up">
        <span class="ad-section-tag">Productos</span>
        <h2>Manufactura y Diseño Industrial</h2>
        <p>Soluciones para el desarrollo de productos y automatización industrial.</p>
      </div>
      <div class="products-grid">
        {mfgProducts.map((product) => (
          <a href={product.href} class="product-card fade-up">
            <div class="product-card-logo">
              <img src={product.logo} alt={product.name} loading="lazy" />
            </div>
            <div class="product-card-info">
              <h3>{product.name}</h3>
              <p>{product.desc}</p>
            </div>
            <span class="product-card-arrow">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Subscription plans -->
  <section class="ad-plans">
    <div class="ad-plans-inner">
      <div class="section-header fade-up">
        <span class="ad-section-tag">Planes</span>
        <h2>¿Cómo adquirir tu suscripción?</h2>
        <p>Elige el plan que mejor se adapte a las necesidades de tu empresa.</p>
      </div>
      <div class="plans-grid">
        <div class="plan-card fade-up">
          <div class="plan-header">
            <span class="plan-duration">1 Año</span>
            <h3>Suscripción Anual</h3>
          </div>
          <ul class="plan-features">
            <li>Acceso completo al software</li>
            <li>Actualizaciones incluidas</li>
            <li>25 GB almacenamiento nube</li>
            <li>Soporte técnico Autodesk</li>
            <li>Acceso a versiones previas</li>
            <li>Renovación flexible</li>
          </ul>
          <a href="/contacto" class="plan-btn">Cotizar ahora</a>
        </div>
        <div class="plan-card plan-card--featured fade-up">
          <div class="plan-popular">Recomendado</div>
          <div class="plan-header">
            <span class="plan-duration">3 Años</span>
            <h3>Suscripción Trianual</h3>
          </div>
          <ul class="plan-features">
            <li>Todo lo del plan anual</li>
            <li><strong>Precio fijo garantizado</strong></li>
            <li>Mayor ahorro por periodo</li>
            <li>Sin incrementos de precio</li>
            <li>Continuidad asegurada</li>
            <li>Renovación simplificada</li>
          </ul>
          <a href="/contacto" class="plan-btn plan-btn--primary">Cotizar ahora</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="ad-benefits">
    <div class="ad-benefits-bg"></div>
    <div class="ad-benefits-inner">
      <div class="section-header fade-up">
        <span class="ad-section-tag ad-section-tag--light">¿Por qué con nosotros?</span>
        <h2>Beneficios Semco</h2>
        <p>Al adquirir o renovar sus suscripciones con nosotros, accede a estos beneficios exclusivos.</p>
      </div>
      <div class="semco-grid">
        <div class="semco-card fade-up">
          <div class="semco-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          </div>
          <h3>Asesoría gratuita</h3>
          <p>Lo ayudamos a elegir las soluciones de software específicas para su negocio.</p>
        </div>
        <div class="semco-card fade-up">
          <div class="semco-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
          </div>
          <h3>Soporte de implementación</h3>
          <p>Acompañamiento en la instalaci��n y configuración de su software.</p>
        </div>
        <div class="semco-card fade-up">
          <div class="semco-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <h3>Soporte técnico local</h3>
          <p>Respuesta rápida ante problemas técnicos y dudas desde Perú.</p>
        </div>
        <div class="semco-card fade-up">
          <div class="semco-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          </div>
          <h3>Facturación local</h3>
          <p>Obtenga beneficios tributarios por compras locales en Perú.</p>
        </div>
        <div class="semco-card fade-up">
          <div class="semco-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          </div>
          <h3>Capacitación certificada</h3>
          <p>Acceda a capacitaciones con certificación de valor internacional.</p>
        </div>
        <div class="semco-card fade-up">
          <div class="semco-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          </div>
          <h3>+38 años de experiencia</h3>
          <p>Más de tres décadas como socio estratégico de valor agregado en el Perú.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="ad-cta">
    <div class="ad-cta-inner fade-up">
      <h2>¿Listo para potenciar tus proyectos?</h2>
      <p>Contáctanos para cotizar la solución Autodesk que se ajuste mejor a las necesidades de tu empresa.</p>
      <div class="ad-cta-actions">
        <a href="/contacto" class="btn-primary">Solicitar cotización</a>
        <a href="tel:+5112027908" class="btn-outline">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          (01) 202 7908 Anx. 108
        </a>
      </div>
      <p class="ad-cta-contact">
        <strong>Ejecutiva de licencias:</strong> Jessica Vera —
        <a href="mailto:jessica.vera@semco.com.pe">jessica.vera@semco.com.pe</a> —
        <a href="tel:+51989682633">989 682 633</a>
      </p>
    </div>
  </section>

</Layout>

<style>
  /* ===== Hero ===== */
  .ad-hero {
    position: relative;
    min-height: 420px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .ad-hero-bg {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(135deg, rgba(0, 40, 80, 0.95) 0%, rgba(26, 35, 50, 0.9) 50%, rgba(0, 100, 160, 0.8) 100%),
      url('/servicios/autodesk.jpg') center/cover no-repeat;
    z-index: 0;
  }

  .ad-hero-bg::before {
    content: '';
    position: absolute;
    top: -30%;
    right: -10%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(0, 170, 224, 0.1) 0%, transparent 70%);
    border-radius: 50%;
  }

  .ad-hero-bg::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(0, 170, 224, 0.4), transparent);
  }

  .ad-hero-inner {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    margin: 0 auto;
    padding: 7rem 2rem 4rem;
    width: 100%;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: rgba(176, 190, 197, 0.7);
    margin-bottom: 2rem;
  }

  .breadcrumb a {
    color: rgba(176, 190, 197, 0.7);
    transition: color 0.3s ease;
  }

  .breadcrumb a:hover { color: #00aae0; }
  .breadcrumb svg { opacity: 0.4; }
  .breadcrumb span { color: var(--white); }

  .ad-badge {
    display: inline-block;
    background: rgba(0, 170, 224, 0.12);
    color: #00aae0;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    padding: 0.4rem 1rem;
    border-radius: 100px;
    border: 1px solid rgba(0, 170, 224, 0.2);
    margin-bottom: 1rem;
  }

  .ad-hero-content h1 {
    font-size: 3rem;
    font-weight: 800;
    color: var(--white);
    margin-bottom: 1rem;
    line-height: 1.15;
  }

  .ad-hero-content > p {
    font-size: 1.15rem;
    color: rgba(176, 190, 197, 0.85);
    max-width: 620px;
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .ad-hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* ===== Buttons ===== */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--orange);
    color: var(--white);
    padding: 0.9rem 2rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.3s ease;
    border: 2px solid var(--orange);
  }

  .btn-primary:hover {
    background: var(--orange-hover);
    border-color: var(--orange-hover);
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(255, 107, 53, 0.3);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: transparent;
    color: var(--white);
    padding: 0.9rem 2rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.95rem;
    border: 2px solid rgba(255, 255, 255, 0.3);
    transition: all 0.3s ease;
  }

  .btn-secondary:hover {
    border-color: var(--white);
    background: rgba(255, 255, 255, 0.08);
    transform: translateY(-2px);
  }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: transparent;
    color: var(--orange);
    padding: 0.9rem 2rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.95rem;
    border: 2px solid var(--orange);
    transition: all 0.3s ease;
  }

  .btn-outline:hover {
    background: rgba(255, 107, 53, 0.08);
    transform: translateY(-2px);
  }

  /* ===== Section common ===== */
  .section-header {
    text-align: center;
    max-width: 620px;
    margin: 0 auto 3rem;
  }

  .ad-section-tag {
    display: inline-block;
    background: linear-gradient(135deg, rgba(255, 107, 53, 0.1), rgba(255, 107, 53, 0.05));
    color: var(--orange);
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    padding: 0.35rem 1rem;
    border-radius: 100px;
    margin-bottom: 1rem;
    border: 1px solid rgba(255, 107, 53, 0.15);
  }

  .ad-section-tag--light {
    background: rgba(255, 255, 255, 0.08);
    color: var(--white);
    border-color: rgba(255, 255, 255, 0.12);
  }

  .section-header h2 {
    font-size: 2.2rem;
    font-weight: 800;
    margin-bottom: 0.75rem;
    line-height: 1.2;
  }

  .section-header p {
    font-size: 1rem;
    color: var(--gray-600);
    line-height: 1.6;
  }

  /* ===== Intro ===== */
  .ad-intro {
    padding: 5rem 2rem;
    background: var(--white);
  }

  .ad-intro-inner {
    max-width: 1100px;
