---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Eventos - SemcoCAD" description="Webinars, talleres y eventos presenciales de SemcoCAD. Mantente actualizado en CAD, BIM y CAE.">
  <section class="page-header">
    <div class="page-header-bg"></div>
    <div class="page-header-inner">
      <h1>Eventos</h1>
      <p>Webinars, talleres y eventos presenciales para mantenerte actualizado en las últimas tecnologías CAD, BIM y CAE.</p>
    </div>
  </section>

  <!-- Featured event -->
  <section class="featured">
    <div class="featured-inner">
      <div class="featured-badge fade-up">Evento destacado</div>
      <a href="/eventos/del-caos-al-control" class="featured-card fade-up">
        <div class="featured-img">
          <img src="/webinar-caos-control.png" alt="Webinar: Del Caos al Control" loading="lazy" />
          <span class="featured-live">EN VIVO</span>
        </div>
        <div class="featured-content">
          <div class="featured-meta">
            <span class="badge badge-webinar">Webinar gratuito</span>
            <span class="featured-date">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              Lun 06 Abril — 08:00 PM
            </span>
          </div>
          <h2>Del Caos al Control: Cómo centralizar la información en proyectos de construcción</h2>
          <p>Descubre cómo implementar un Entorno Común de Datos (CDE) para eliminar la dispersión documental y mejorar la coordinación en tus proyectos AEC.</p>
          <span class="featured-cta">Ver detalles e inscribirme <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
        </div>
      </a>
    </div>
  </section>

  <!-- Upcoming events -->
  <section class="events">
    <h2 class="events-title fade-up">Próximos eventos</h2>

    <div class="event-card fade-up">
      <div class="event-date">
        <span class="day">06</span>
        <span class="month">ABR</span>
      </div>
      <div class="event-info">
        <span class="badge badge-webinar">Webinar</span>
        <h3><a href="/eventos/del-caos-al-control">Del Caos al Control: Centralizar información en construcción</a></h3>
        <p>Webinar gratuito en vivo. Aprende sobre entornos comunes de datos (CDE) y gestión documental en la nube.</p>
        <a href="/eventos/del-caos-al-control" class="btn-register">Inscribirme</a>
      </div>
    </div>

    <div class="event-card fade-up">
      <div class="event-date">
        <span class="day">15</span>
        <span class="month">ABR</span>
      </div>
      <div class="event-info">
        <span class="badge badge-webinar">Webinar</span>
        <h3>Introducción a Revit 2026: Novedades y flujo BIM</h3>
        <p>Descubre las nuevas funcionalidades de Revit 2026 y cómo optimizar tu flujo de trabajo BIM.</p>
        <a href="/contacto" class="btn-register">Registrarse</a>
      </div>
    </div>

    <div class="event-card fade-up">
      <div class="event-date">
        <span class="day">28</span>
        <span class="month">ABR</span>
      </div>
      <div class="event-info">
        <span class="badge badge-presencial">Presencial</span>
        <h3>Taller de Simulación Estructural con Ansys</h3>
        <p>Taller práctico en nuestras oficinas de Lima. Análisis de elementos finitos para validar diseños mecánicos.</p>
        <a href="/contacto" class="btn-register">Registrarse</a>
      </div>
    </div>

    <div class="event-card fade-up">
      <div class="event-date">
        <span class="day">10</span>
        <span class="month">MAY</span>
      </div>
      <div class="event-info">
        <span class="badge badge-webinar">Webinar</span>
        <h3>Automatización de planos con AutoCAD y Dynamo</h3>
        <p>Técnicas de automatización para generar planos y documentación de manera eficiente.</p>
        <a href="/contacto" class="btn-register">Registrarse</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header{position:relative;padding:4rem 2rem 3rem;text-align:center;overflow:hidden}
  .page-header-bg{position:absolute;inset:0;background:linear-gradient(135deg,#0f1923,#1a2332 50%,#1e3a5f)}
  .page-header-inner{position:relative;z-index:1;max-width:700px;margin:0 auto}
  .page-header h1{color:var(--white);font-size:2.5rem;margin-bottom:.75rem}
  .page-header p{color:#b0bec5;max-width:600px;margin:0 auto;font-size:1.05rem}

  /* Featured */
  .featured{max-width:1100px;margin:0 auto;padding:3rem 2rem 0}
  .featured-inner{position:relative}
  .featured-badge{display:inline-block;background:rgba(255,107,53,.1);color:var(--orange);font-size:.78rem;font-weight:700;text-transform:uppercase;letter-spacing:2px;padding:.35rem 1rem;border-radius:100px;border:1px solid rgba(255,107,53,.15);margin-bottom:1rem}
  .featured-card{display:grid;grid-template-columns:1.2fr 1fr;background:var(--white);border:1px solid var(--gray-200);border-radius:16px;overflow:hidden;transition:all .4s;text-decoration:none;color:inherit}
  .featured-card:hover{box-shadow:0 16px 50px rgba(0,0,0,.1);transform:translateY(-4px);border-color:rgba(255,107,53,.2)}
  .featured-img{position:relative;overflow:hidden;min-height:280px}
  .featured-img img{width:100%;height:100%;object-fit:cover;transition:transform .6s}
  .featured-card:hover .featured-img img{transform:scale(1.05)}
  .featured-live{position:absolute;top:1rem;left:1rem;background:#e53935;color:var(--white);font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;padding:.3rem .8rem;border-radius:4px;animation:live-pulse 2s ease-in-out infinite}
  @keyframes live-pulse{0%,100%{opacity:1}50%{opacity:.6}}
  .featured-content{padding:2rem;display:flex;flex-direction:column;justify-content:center}
  .featured-meta{display:flex;align-items:center;gap:.75rem;margin-bottom:.75rem;flex-wrap:wrap}
  .featured-date{display:flex;align-items:center;gap:.35rem;font-size:.85rem;color:var(--gray-600);font-weight:500}
  .featured-content h2{font-size:1.4rem;font-weight:800;margin-bottom:.75rem;line-height:1.3}
  .featured-content p{font-size:.92rem;color:var(--gray-600);line-height:1.6;margin-bottom:1rem}
  .featured-cta{display:inline-flex;align-items:center;gap:.4rem;font-size:.9rem;font-weight:600;color:var(--orange);transition:gap .3s}
  .featured-card:hover .featured-cta{gap:.8rem}

  /* Events list */
  .events{max-width:800px;margin:0 auto;padding:2.5rem 2rem 5rem;display:flex;flex-direction:column;gap:1.2rem}
  .events-title{font-size:1.4rem;font-weight:800;margin-bottom:.5rem;padding-bottom:.5rem;border-bottom:2px solid var(--gray-200);position:relative}
  .events-title::after{content:'';position:absolute;bottom:-2px;left:0;width:50px;height:2px;background:var(--orange)}

  .event-card{display:flex;gap:1.5rem;background:var(--white);border:1px solid var(--gray-200);border-radius:12px;padding:1.5rem;transition:all .3s}
  .event-card:hover{box-shadow:0 8px 25px rgba(0,0,0,.06);border-color:rgba(255,107,53,.15);transform:translateY(-2px)}
  .event-date{flex-shrink:0;width:70px;text-align:center;padding:.75rem 0;background:var(--gray-50);border-radius:10px;display:flex;flex-direction:column;align-items:center;justify-content:center}
  .event-date .day{font-size:1.75rem;font-weight:800;color:var(--orange);line-height:1}
  .event-date .month{font-size:.8rem;font-weight:600;color:var(--gray-600);text-transform:uppercase;margin-top:.25rem}
  .event-info h3{font-size:1.05rem;margin-bottom:.4rem;margin-top:.4rem}
  .event-info h3 a{color:inherit;transition:color .3s}
  .event-info h3 a:hover{color:var(--orange)}
  .event-info p{font-size:.88rem;color:var(--gray-600);margin-bottom:.75rem;line-height:1.5}
  .badge{display:inline-block;font-size:.72rem;font-weight:700;padding:.2rem .7rem;border-radius:50px;text-transform:uppercase;letter-spacing:.5px}
  .badge-webinar{background:#e3f2fd;color:#1565c0}
  .badge-presencial{background:#e8f5e9;color:#2e7d32}
  .btn-register{display:inline-block;background:var(--orange);color:var(--white);padding:.5rem 1.3rem;border-radius:8px;font-weight:600;font-size:.85rem;transition:all .3s}
  .btn-register:hover{background:var(--orange-hover);transform:translateY(-1px)}

  .fade-up{opacity:0;transform:translateY(30px);transition:opacity .7s cubic-bezier(.25,.46,.45,.94),transform .7s cubic-bezier(.25,.46,.45,.94)}
  .fade-up.visible{opacity:1;transform:translateY(0)}

  @media(max-width:768px){.featured-card{grid-template-columns:1fr}.featured-img{min-height:200px}.event-card{flex-direction:column}.event-date{width:100%;flex-direction:row;gap:.5rem;padding:.5rem}}
</style>

<script>
  const o = new IntersectionObserver(e => { e.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); o.unobserve(e.target); } }); }, { threshold: 0.1 });
  document.querySelectorAll('.fade-up').forEach(e => o.observe(e));
</script>
