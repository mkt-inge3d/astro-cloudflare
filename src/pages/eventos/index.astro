<style>
  .page-header{position:relative;padding:4rem 2rem 3rem;text-align:center;overflow:hidden}
  .page-header-bg{position:absolute;inset:0;background:linear-gradient(135deg,#0f1923,#1a2332 50%,#1e3a5f)}
  .page-header-inner{position:relative;z-index:1;max-width:700px;margin:0 auto}
  .page-header h1{color:var(--white);font-size:2.5rem;margin-bottom:.75rem}
  .page-header p{color:#b0bec5;max-width:600px;margin:0 auto;font-size:1.05rem}

  /* Upcoming events */
  .upcoming-events{max-width:1100px;margin:0 auto;padding:2.5rem 2rem 1rem}
  .events-title{font-size:1.4rem;font-weight:800;margin-bottom:.5rem;padding-bottom:.5rem;border-bottom:2px solid var(--gray-200);position:relative}
  .events-title::after{content:'';position:absolute;bottom:-2px;left:0;width:50px;height:2px;background:var(--orange)}
  .upcoming-badge{position:absolute;top:.75rem;left:.75rem;background:var(--orange);color:#fff;font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;padding:.25rem .7rem;border-radius:4px}
  .btn-upcoming{color:var(--orange);font-weight:700}
  .badge{display:inline-block;font-size:.72rem;font-weight:700;padding:.2rem .7rem;border-radius:50px;text-transform:uppercase;letter-spacing:.5px}
  .badge-webinar{background:#e3f2fd;color:#1565c0}
  .badge-presencial{background:#e8f5e9;color:#2e7d32}

  /* Past events section */
  .past-events{max-width:1100px;margin:0 auto;padding:1rem 2rem 5rem}
  .past-subtitle{font-size:.95rem;color:var(--gray-600);margin-bottom:1.5rem;margin-top:-.25rem}

  .filter-tabs{display:flex;gap:.5rem;margin-bottom:2rem;flex-wrap:wrap}
  .filter-tab{padding:.45rem 1.1rem;border:1px solid var(--gray-200);border-radius:100px;font-size:.82rem;font-weight:600;cursor:pointer;background:var(--white);color:var(--gray-600);transition:all .3s}
  .filter-tab:hover{border-color:var(--orange);color:var(--orange)}
  .filter-tab.active{background:var(--orange);color:#fff;border-color:var(--orange)}

  .past-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.2rem}

  .past-card{display:flex;flex-direction:column;background:var(--white);border:1px solid var(--gray-200);border-radius:12px;overflow:hidden;transition:all .3s;text-decoration:none;color:inherit}
  .past-card-img{position:relative;width:100%;height:160px;overflow:hidden}
  .past-card-img img{width:100%;height:100%;object-fit:cover;transition:transform .4s}
  .past-card:hover .past-card-img img{transform:scale(1.05)}
  .past-card-body{padding:1.2rem;display:flex;flex-direction:column;flex:1}
  .past-card:hover{box-shadow:0 8px 25px rgba(0,0,0,.06);border-color:rgba(255,107,53,.15);transform:translateY(-3px)}
  .past-card.hidden{display:none}
  .past-card-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:.75rem}
  .past-date{font-size:.75rem;font-weight:700;color:var(--gray-600);letter-spacing:.5px}
  .past-card h3{font-size:1rem;font-weight:700;margin-bottom:.4rem;line-height:1.35}
  .past-card p{font-size:.85rem;color:var(--gray-600);line-height:1.5;margin-bottom:.75rem;flex:1}
  .past-link{display:inline-flex;align-items:center;gap:.35rem;font-size:.84rem;font-weight:600;color:var(--orange);transition:gap .3s}
  .past-card:hover .past-link{gap:.7rem}

  .fade-up{opacity:0;transform:translateY(30px);transition:opacity .7s cubic-bezier(.25,.46,.45,.94),transform .7s cubic-bezier(.25,.46,.45,.94)}
  .fade-up.visible{opacity:1;transform:translateY(0)}

  @media(max-width:900px){.past-grid{grid-template-columns:repeat(2,1fr)}}
  @media(max-width:550px){.past-grid{grid-template-columns:1fr}}
</style>

<script>
  const o = new IntersectionObserver(e => { e.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); o.unobserve(e.target); } }); }, { threshold: 0.1 });
  document.querySelectorAll('.fade-up').forEach(e => o.observe(e));

  // Filter functionality
  document.querySelectorAll('.filter-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.filter-tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      const filter = tab.getAttribute('data-filter');
      document.querySelectorAll('.past-card').forEach(card => {
        if (filter === 'all' || card.getAttribute('data-category') === filter) {
          card.classList.remove('hidden');
        } else {
          card.classList.add('hidden');
        }
      });
    });
  });
</script>
