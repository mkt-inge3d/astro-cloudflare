---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Cotizar / Contacto - SemcoCAD">
  <section class="page-header">
    <h1>Cotizar / Contacto</h1>
    <p>Escríbenos y te responderemos en menos de 24 horas.</p>
  </section>

  <section class="contact-section">
    <div class="contact-grid">
      <!-- Formulario -->
      <form class="contact-form" action="#" method="POST">
        <div class="form-group">
          <label for="name">Nombre completo</label>
          <input type="text" id="name" name="name" required placeholder="Tu nombre" />
        </div>
        <div class="form-group">
          <label for="email">Correo electrónico</label>
          <input type="email" id="email" name="email" required placeholder="correo@ejemplo.com" />
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="phone">Teléfono</label>
            <input type="tel" id="phone" name="phone" placeholder="+51 999 999 999" />
          </div>
          <div class="form-group">
            <label for="company">Empresa</label>
            <input type="text" id="company" name="company" placeholder="Nombre de tu empresa" />
          </div>
        </div>
        <div class="form-group">
          <label for="interest">¿En qué estás interesado?</label>
          <select id="interest" name="interest" required>
            <option value="" disabled selected>Selecciona una opción</option>
            <option value="licencia">Licencia de software</option>
            <option value="curso">Curso de capacitación</option>
            <option value="especializacion">Especialización</option>
            <option value="servicio">Servicio de ingeniería</option>
          </select>
        </div>
        <div class="form-group">
          <label for="message">Mensaje</label>
          <textarea id="message" name="message" rows="5" placeholder="Cuéntanos sobre tu proyecto o requerimiento..."></textarea>
        </div>
        <button type="submit" class="btn-submit">Enviar mensaje</button>
      </form>

      <!-- Info de contacto -->
      <div class="contact-info">
        <h3>Información de contacto</h3>

        <div class="info-item">
          <span class="info-icon">📧</span>
          <div>
            <strong>Correo electrónico</strong>
            <p>ventas@semcocad.com</p>
          </div>
        </div>

        <div class="info-item">
          <span class="info-icon">📞</span>
          <div>
            <strong>Teléfono</strong>
            <p>+51 (1) 422-3456</p>
          </div>
        </div>

        <div class="info-item">
          <span class="info-icon">📍</span>
          <div>
            <strong>Dirección</strong>
            <p>Av. Javier Prado Este 456, Oficina 301<br />San Isidro, Lima, Perú</p>
          </div>
        </div>

        <div class="info-item">
          <span class="info-icon">🕐</span>
          <div>
            <strong>Horario de atención</strong>
            <p>Lunes a Viernes: 9:00 a.m. - 6:00 p.m.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    background: var(--navy);
    color: var(--white);
    padding: 4rem 2rem 3rem;
    text-align: center;
  }

  .page-header h1 {
    color: var(--white);
    font-size: 2.5rem;
    margin-bottom: 0.75rem;
  }

  .page-header p {
    color: #b0bec5;
    font-size: 1.05rem;
  }

  .contact-section {
    max-width: 1050px;
    margin: 0 auto;
    padding: 3rem 2rem 5rem;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  /* Form */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .form-group label {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--navy);
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    padding: 0.7rem 0.85rem;
    border: 1px solid var(--gray-200);
    border-radius: var(--radius);
    font-size: 0.95rem;
    transition: border-color var(--transition);
    background: var(--white);
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--orange);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .btn-submit {
    background: var(--orange);
    color: var(--white);
    border: none;
    padding: 0.85rem 2rem;
    border-radius: var(--radius);
    font-weight: 600;
    font-size: 1rem;
    cursor: pointer;
    transition: background var(--transition);
    align-self: flex-start;
  }

  .btn-submit:hover {
    background: var(--orange-hover);
  }

  /* Contact info */
  .contact-info {
    background: var(--gray-50);
    border-radius: var(--radius);
    padding: 2rem;
  }

  .contact-info h3 {
    font-size: 1.2rem;
    margin-bottom: 1.5rem;
  }

  .info-item {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.5rem;
    align-items: flex-start;
  }

  .info-item:last-child {
    margin-bottom: 0;
  }

  .info-icon {
    font-size: 1.25rem;
    flex-shrink: 0;
    margin-top: 0.15rem;
  }

  .info-item strong {
    display: block;
    font-size: 0.9rem;
    color: var(--navy);
    margin-bottom: 0.15rem;
  }

  .info-item p {
    font-size: 0.9rem;
    color: var(--gray-600);
  }

  @media (max-width: 700px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>
