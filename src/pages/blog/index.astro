---
import Layout from '../../layouts/Layout.astro';

const posts = [
  {
    category: 'BIM',
    title: 'Cómo implementar BIM en proyectos de infraestructura en Perú',
    excerpt: 'Una guía paso a paso para adoptar la metodología BIM en proyectos de infraestructura pública y privada, cumpliendo con la normativa peruana.',
    date: '20 Mar 2026',
    color: '#1565c0',
  },
  {
    category: 'CAD',
    title: 'AutoCAD 2026: 5 funciones que mejorarán tu productividad',
    excerpt: 'Repasamos las novedades más relevantes de AutoCAD 2026 y cómo aprovecharlas para optimizar tus flujos de diseño diarios.',
    date: '8 Mar 2026',
    color: '#e65100',
  },
  {
    category: 'Simulación',
    title: 'Introducción al análisis de elementos finitos con Ansys',
    excerpt: 'Conceptos fundamentales del FEA y cómo aplicar Ansys Mechanical para validar diseños antes de la manufactura.',
    date: '22 Feb 2026',
    color: '#2e7d32',
  },
];
---

<Layout title="Blog - SemcoCAD">
  <section class="page-header">
    <h1>Blog</h1>
    <p>Artículos, tutoriales y noticias sobre el mundo CAD, BIM y CAE.</p>
  </section>

  <section class="blog-grid-section">
    <div class="blog-grid">
      {posts.map((post) => (
        <article class="blog-card">
          <div class="blog-image" style={`background-color: ${post.color};`}>
            <span class="blog-category">{post.category}</span>
          </div>
          <div class="blog-body">
            <h3>{post.title}</h3>
            <p>{post.excerpt}</p>
            <div class="blog-footer">
              <span class="blog-date">{post.date}</span>
              <a href="#" class="read-more">Leer más &rarr;</a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>
</Layout>

<style>
  .page-header {
    background: var(--navy);
    color: var(--white);
    padding: 4rem 2rem 3rem;
    text-align: center;
  }

  .page-header h1 {
    color: var(--white);
    font-size: 2.5rem;
    margin-bottom: 0.75rem;
  }

  .page-header p {
    color: #b0bec5;
    max-width: 600px;
    margin: 0 auto;
    font-size: 1.05rem;
  }

  .blog-grid-section {
    max-width: 1100px;
    margin: 0 auto;
    padding: 3rem 2rem 5rem;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .blog-card {
    border: 1px solid var(--gray-200);
    border-radius: var(--radius);
    overflow: hidden;
    transition: box-shadow var(--transition), transform var(--transition);
    background: var(--white);
  }

  .blog-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-3px);
  }

  .blog-image {
    height: 180px;
    display: flex;
    align-items: flex-end;
    padding: 1rem;
  }

  .blog-category {
    background: rgba(255, 255, 255, 0.9);
    color: var(--navy);
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.2rem 0.65rem;
    border-radius: 50px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .blog-body {
    padding: 1.25rem 1.5rem 1.5rem;
  }

  .blog-body h3 {
    font-size: 1.1rem;
    margin-bottom: 0.6rem;
    line-height: 1.4;
  }

  .blog-body p {
    font-size: 0.9rem;
    color: var(--gray-600);
    margin-bottom: 1.25rem;
  }

  .blog-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .blog-date {
    font-size: 0.82rem;
    color: var(--gray-400);
  }

  .read-more {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--orange);
    transition: color var(--transition);
  }

  .read-more:hover {
    color: var(--orange-hover);
  }
</style>
